# .gitignore for a C++ project using CMake
# Compiled object files, libraries and executables
*.o
*.obj
*.lo
*.slo

# Static libraries
*.a
*.lib

# Shared libraries and dynamic libs
*.so
*.dylib
*.dll

# Executables
*.exe
*.out
a.out
*.app

# Precompiled headers
*.gch
*.pch

# Debugging files
*.dSYM/
*.su
*.idb
*.pdb

# Build directories
/build/
/build-*/
/cmake-build*/
bin/
lib/
lib64/
Debug/
Release/
out/

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
cmake_uninstall.cmake
install_manifest.txt
Makefile

# Compile commands (often generated)
compile_commands.json

# Ninja build system
build.ninja
.ninja_deps
.ninja_log

# Coverage and profiling
*.gcno
*.gcda
*.gcov
coverage/
lcov-report/

# Logs and temporary files
*.log
*.tmp
*.temp
*.bak
*.swp
*~

# IDEs and editor folders
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# Xcode
*.xcworkspace
*.xcuserdata
*.xccheckout
*.xcuserstate
DerivedData/

# macOS files
.DS_Store

# Windows files
Thumbs.db
desktop.ini

# Tags and indexing
tags
cscope.*
ctags

# Package managers and build helpers
conanbuildinfo.*
conaninfo.txt
conanfile.txt
vcpkg_installed/
vcpkg.json

# Optional: ignore vendor/third-party build outputs
*/third_party/*/build/
